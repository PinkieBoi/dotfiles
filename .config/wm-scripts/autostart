## Restore Wallpaper
variety &

## xfce4-settings daemon
xfsettingsd &
## polkit agent
/usr/lib/xfce-polkit/xfce-polkit &
## Start Compositing Manager
picom --config $HOME/.config/qtile/scripts/picom.conf &
## Start Music Player Daemon
exec mpd &
## Notification Daemon
exec dunst &
## Thunar Daemon
exec thunar --daemon &
## Enable power management
xfce4-power-manager &

